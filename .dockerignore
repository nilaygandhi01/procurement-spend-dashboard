# Keep the runtime image lean and prevent sensitive payloads from leaking
# into the container. Aligned with docs/DEPLOYMENT.md → Deployer K8s PaaS.

# Sensitive client data — NEVER bake into the image.
data/outputs/
data.json
**/data.json

# Spend workbooks (potentially client data).
*.xlsx
!data/inputs/indexes/*.xlsx
!data/samples/example-excels/*.xlsx

# Dev artifacts
.git/
.github/
.vscode/
.idea/
node_modules/
**/node_modules/
__pycache__/
**/__pycache__/
*.pyc

# Local logs / scratch
*.log
scratch/
tmp/
terminals/

# Local-only HTML copy with Tailwind Play CDN injected for `python -m http.server`.
# Production must NOT bake this into the image (the Dockerfile sanity check
# enforces no cdn.tailwindcss.com in index.html, but this file is a separate
# artifact that should never leave the developer's machine).
src/dashboard/Cummins_IDP_Dashboard.html

# Tests / docs that don't need to ship
tests/
docs/
*.md
!README.md

# Tooling
scripts/
src/scripts/
requirements.txt
netlify.toml
